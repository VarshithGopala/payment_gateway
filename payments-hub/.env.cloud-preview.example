# Copy to .env to run the one-URL storefront preview locally.
# This uses mock checkout, so no real card is charged.

NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
INTERNAL_BASE_URL=http://127.0.0.1:8080
DATA_DIR=./data
PAYMENT_PROVIDER=mock

SITES=demo-store
SITE_DEMO_STORE_NAME=Launch Kit Store
SITE_DEMO_STORE_SECRET=preview_merchant_to_gateway_secret_change_me_64_chars_minimum
SITE_DEMO_STORE_ORIGINS={PUBLIC_BASE_URL}
SITE_DEMO_STORE_FULFILLMENT_URL={PUBLIC_BASE_URL}/store/api/payments/webhook
SITE_DEMO_STORE_FULFILLMENT_SECRET=preview_gateway_to_merchant_secret_change_me_64_chars_minimum

STORE_ENABLED=true
STORE_SITE_ID=demo-store
STORE_NAME=Launch Kit Store
STORE_PRODUCT_NAME=Website Launch Kit
STORE_PRODUCT_DESCRIPTION=A secure starter purchase wired through your reusable payments hub.
STORE_PRODUCT_PRICE_CENTS=4900
STORE_CURRENCY=inr
STORE_CUSTOMER_EMAIL=customer@example.com

REQUEST_SIGNATURE_TOLERANCE_SECONDS=300
STRIPE_SIGNATURE_TOLERANCE_SECONDS=300
TRUST_PROXY=false
