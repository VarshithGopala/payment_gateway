# Copy this file to .env and fill the real values.
# This gateway intentionally uses hosted Checkout so card data never touches your server.

NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
# Internal URL used when the integrated store calls the hub API in the same app.
INTERNAL_BASE_URL=http://127.0.0.1:8080
DATA_DIR=./data

# Use auto for real payments: INR routes to Razorpay, non-INR routes to Stripe.
# Use mock only for local/cloud preview without charging cards.
PAYMENT_PROVIDER=auto

# Stripe
# Use sk_test_* while developing. Switch to sk_live_* only after webhook + fulfillment testing.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optional: set only when you intentionally pin your Stripe account API version.
# STRIPE_API_VERSION=2025-xx-xx

# Razorpay
# Use rzp_test_* while developing. Enable international payments in Razorpay Dashboard if needed.
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# Comma-separated site IDs that may create payments through this hub.
SITES=demo-store

# Per-site settings. Site IDs are uppercased and non-alphanumeric chars become underscores.
SITE_DEMO_STORE_NAME=Demo Store
SITE_DEMO_STORE_SECRET=replace_with_64_random_characters_for_merchant_to_gateway_hmac
SITE_DEMO_STORE_ORIGINS={PUBLIC_BASE_URL}
SITE_DEMO_STORE_FULFILLMENT_URL={PUBLIC_BASE_URL}/store/api/payments/webhook
SITE_DEMO_STORE_FULFILLMENT_SECRET=replace_with_64_random_characters_for_gateway_to_merchant_hmac

# Integrated simple storefront at /store
STORE_ENABLED=true
STORE_SITE_ID=demo-store
STORE_NAME=Launch Kit Store
STORE_PRODUCT_NAME=Website Launch Kit
STORE_PRODUCT_DESCRIPTION=A secure starter purchase wired through your reusable payments hub.
STORE_PRODUCT_PRICE_CENTS=49900
STORE_CURRENCY=inr
STORE_CUSTOMER_EMAIL=customer@example.com

# Security knobs
REQUEST_SIGNATURE_TOLERANCE_SECONDS=300
STRIPE_SIGNATURE_TOLERANCE_SECONDS=300
TRUST_PROXY=false
